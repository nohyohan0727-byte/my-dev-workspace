    /* ── create_user ── */
    {
      "parameters": {
        "jsCode": "const d = $('액션 파싱').item.json;\nconst { email, name, role, tokens_remaining, company_id } = d.data;\nconst companyId = company_id || d.companyId;\nif (!email || !name) return [{ json: { success: false, message: '이메일과 이름 필수' } }];\n// API 키 생성\nconst apiKey = 'trust_' + Array.from(crypto.getRandomValues(new Uint8Array(24))).map(b => b.toString(16).padStart(2,'0')).join('');\nreturn [{ json: { email: email.trim(), name: name.trim(), role: role || 'user', tokens: tokens_remaining || 1000, companyId, apiKey } }];"
      },
      "id": "prep-create-user",
      "name": "Prep: create_user",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 520]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO tr_users (company_id, email, name, role, api_key, tokens_remaining) VALUES ('{{ $json.companyId }}'::uuid, '{{ $json.email }}', '{{ $json.name }}', '{{ $json.role }}', '{{ $json.apiKey }}', {{ $json.tokens }}) ON CONFLICT (api_key) DO NOTHING RETURNING id, email, name, role, api_key, tokens_remaining, created_at",
        "options": {}
      },
      "id": "sql-create-user",
      "name": "SQL: create_user",
      "type": "n8n-nodes-base.postgres",
