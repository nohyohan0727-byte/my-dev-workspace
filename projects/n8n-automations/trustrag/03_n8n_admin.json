    /* ── create_category ── */
    {
      "parameters": {
        "jsCode": "const d = $('액션 파싱').item.json;\nconst { name, description } = d.data;\nif (!name) return [{ json: { success: false, message: '카테고리 이름 필수' } }];\n// table_name 생성: tr_docs_{companySlug}_{catSlug}\nconst slug = name.toLowerCase().replace(/[^a-z0-9가-힣]/g, '_').replace(/_+/g, '_').replace(/^_|_$/g, '');\nconst tableName = 'tr_docs_' + slug + '_' + Date.now().toString(36);\nreturn [{ json: { name: name.trim(), description: description || '', tableName, companyId: d.companyId } }];"
      },
