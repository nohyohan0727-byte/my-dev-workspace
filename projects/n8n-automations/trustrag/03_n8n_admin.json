    /* ── grant/revoke permission & audit_logs (Code 노드로 처리) ── */
    {
      "parameters": {
        "jsCode": "const d = $('액션 파싱').item.json;\nconst action = d.action;\nlet query = '';\n\nif (action === 'grant_permission') {\n  const { user_id, category_id, can_upload } = d.data;\n  query = `INSERT INTO tr_user_permissions (user_id, category_id, can_upload) VALUES ('${user_id}', '${category_id}', ${can_upload || false}) ON CONFLICT (user_id, category_id) DO UPDATE SET can_upload = ${can_upload || false}, granted_at = now()`;\n} else if (action === 'revoke_permission') {\n  const { user_id, category_id } = d.data;\n  query = `DELETE FROM tr_user_permissions WHERE user_id = '${user_id}' AND category_id = '${category_id}'`;\n} else if (action === 'get_audit_logs') {\n  const limit = d.data.limit || 20;\n  query = `SELECT l.created_at, u.name AS user_name, l.user_id, l.action, l.query_text, l.session_id FROM tr_audit_logs l LEFT JOIN tr_users u ON u.id = l.user_id WHERE l.company_id = '${d.companyId}' ORDER BY l.created_at DESC LIMIT ${limit}`;\n}\n\nreturn [{ json: { query, action } }];"
      },
      "id": "build-perm-query",
      "name": "권한/로그 쿼리 생성",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 1080]
