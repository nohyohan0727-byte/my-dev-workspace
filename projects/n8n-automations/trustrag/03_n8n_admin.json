      "position": [1540, 1080],
      "credentials": { "postgres": { "name": "Supabase (Postgres)" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst action = $('권한/로그 쿼리 생성').item.json.action;\nif (action === 'get_audit_logs') return [{ json: { success: true, result: rows } }];\nreturn [{ json: { success: true, result: rows } }];"
      },
      "id": "fmt-perm-action",
      "name": "Format: 권한/로그",
