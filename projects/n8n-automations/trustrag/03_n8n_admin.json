    /* ── create_company ── */
    {
      "parameters": {
        "jsCode": "const d = $('액션 파싱').item.json;\nif (d.userLevel < 4) return [{ json: { success: false, message: '슈퍼 관리자 권한 필요' } }];\nconst { name, slug, plan } = d.data;\nif (!name || !slug) return [{ json: { success: false, message: '회사명과 슬러그 필수' } }];\nif (!/^[a-z0-9][a-z0-9\\-]*[a-z0-9]$/.test(slug) && slug.length > 1) return [{ json: { success: false, message: '슬러그 형식 오류 (소문자·숫자·하이픈)' } }];\nreturn [{ json: { name, slug, plan: plan || 'starter', proceed: true } }];"
      },
      "id": "validate-company",
      "name": "Validate: create_company",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 200]
